theme_btn = Button(top_bar,text="🌙",font=("Segoe UI",14),bd=0,
                   bg=TOP_BAR_COLOR,fg="white",command=toggle_theme)
theme_btn.grid(row=0,column=0,padx=20)

right = Frame(top_bar,bg=TOP_BAR_COLOR)
right.grid(row=0,column=2,sticky="e",padx=20)

def nav(text,cmd):
    Button(right,text=text,font=("Segoe UI",13),bd=0,
           bg=TOP_BAR_COLOR,fg="white",command=cmd).pack(side=LEFT,padx=15)

nav("Home", show_home)
nav("Settings", show_settings)
nav("To-Do List", show_todo)
nav("Calendar", show_calendar)
nav("About Us", show_about)

content = Frame(root,bg="#2c2c2c")
content.pack(fill=BOTH,expand=True)

load_data()
show_home()
root.mainloop()
